{
  "name": "chain_distillation",
  "version": "0.2.0",
  "description": "Provenance-certified distillation of the instance chain into distributable SkillSets (design v0.5 CD-1..CD-6 slice 1: distill and certify; slice 2 CD-7..CD-11: distribution, certificate-carrying packages, revocation end to end)",
  "author": "KairosChain",
  "layer": "L1",
  "depends_on": [
    {
      "name": "confidentiality_guard",
      "version": ">= 0.2.0"
    },
    {
      "name": "synoptis",
      "version": ">= 0.1.0"
    },
    {
      "name": "skillset_exchange",
      "version": ">= 0.1.0"
    }
  ],
  "provides": [
    "chain-distillation",
    "provenance-certificate"
  ],
  "tool_classes": [
    "KairosMcp::SkillSets::ChainDistillation::Tools::CdDistill",
    "KairosMcp::SkillSets::ChainDistillation::Tools::CdVerify",
    "KairosMcp::SkillSets::ChainDistillation::Tools::CdRevoke",
    "KairosMcp::SkillSets::ChainDistillation::Tools::CdDeposit"
  ],
  "config_files": [
    "config/chain_distillation.yml"
  ],
  "min_core_version": "2.8.0"
}
