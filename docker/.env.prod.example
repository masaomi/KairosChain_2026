# KairosChain Meeting Place Server — Production environment
# Copy to .env and set a strong POSTGRES_PASSWORD before deploying.
#
#   cp .env.prod.example .env
#   # Generate a strong password:
#   #   openssl rand -base64 32
#   docker compose -f docker-compose.prod.yml up -d

# Required — use a strong random password
POSTGRES_PASSWORD=

# Optional — override defaults
# POSTGRES_DB=kairoschain
# POSTGRES_USER=kairoschain
