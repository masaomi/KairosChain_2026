# KairosChain Meeting Place Server — Docker environment
# Copy to .env and edit before running docker compose up.
#
#   cp .env.example .env
#   # Edit POSTGRES_PASSWORD to a strong value for production
#   docker compose up -d

# Required — PostgreSQL password (no default; compose will fail without it)
POSTGRES_PASSWORD=changeme

# Optional — override defaults
# POSTGRES_DB=kairoschain
# POSTGRES_USER=kairoschain
# KAIROS_PORT=8080
