meeting.genomicschain.io {
	# Static landing page for browser visitors
	handle / {
		root * /srv/static
		file_server
	}

	# Frozen verification address for anchored deposits (ANC-7). The public URL
	# /anchor/<slug> is baked into immutable Zenodo documents, so it must resolve
	# durably: rewrite to the app's ANC-7 public view under /place/web/anchor/<slug>.
	handle /anchor/* {
		rewrite * /place/web{uri}
		reverse_proxy meeting-place:8080
	}

	# API routes to KairosChain app
	handle /place/* {
		reverse_proxy meeting-place:8080
	}
	handle /meeting/* {
		reverse_proxy meeting-place:8080
	}
	handle /health {
		reverse_proxy meeting-place:8080
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
